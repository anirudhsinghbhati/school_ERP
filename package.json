{
  "name": "education-analytics-api",
  "version": "1.0.0",
  "description": "Education analytics platform for teachers, parents, and admins",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "db:init": "psql -U postgres -d education_analytics -f schema.sql",
    "db:reset": "psql -U postgres -c 'DROP DATABASE IF EXISTS education_analytics;' && psql -U postgres -c 'CREATE DATABASE education_analytics;' && npm run db:init"
  },
  "keywords": [
    "education",
    "analytics",
    "report-card",
    "teacher",
    "parent",
    "admin"
  ],
  "author": "Student",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.0",
    "pg": "^8.8.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express-async-errors": "^3.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  }
}
